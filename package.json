{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "node ./scripts/prisma-env.mjs generate && next build",
    "start": "node -e \"const {spawn}=require('child_process'); const port=process.env.PORT||3000; const child=spawn(process.execPath,['./node_modules/next/dist/bin/next','start','-p',String(port)],{stdio:'inherit'}); child.on('exit',c=>process.exit(c??1));\"",
    "lint": "tsc --noEmit",
    "prisma:generate": "node ./scripts/prisma-env.mjs generate",
    "prisma:migrate:dev": "node ./scripts/prisma-env.mjs migrate dev",
    "prisma:migrate:deploy": "node ./scripts/prisma-env.mjs migrate deploy",
    "prisma:studio": "node ./scripts/prisma-env.mjs studio",
    "postinstall": "node ./scripts/prisma-env.mjs generate"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@prisma/client": "^6.16.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "mysql2": "^3.15.1",
    "motion": "^12.23.24",
    "next": "^15.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "19.2.14",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "prisma": "^6.16.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
