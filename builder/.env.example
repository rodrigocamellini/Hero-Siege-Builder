# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

MYSQL_HOST="MY_MYSQL_HOST"
MYSQL_PORT="3306"
MYSQL_DATABASE="u814151968_hsbuilder"
MYSQL_USER="u814151968_builder"
MYSQL_PASSWORD="MY_MYSQL_PASSWORD"
MYSQL_SSL="false"
MYSQL_SSL_REJECT_UNAUTHORIZED="false"

HSB_MYSQL_HOST="MY_MYSQL_HOST"
HSB_MYSQL_PORT="3306"
HSB_MYSQL_DATABASE="u814151968_hsbuilder"
HSB_MYSQL_USER="u814151968_builder"
HSB_MYSQL_PASSWORD="MY_MYSQL_PASSWORD"
HSB_MYSQL_SHADOW_DATABASE="u814151968_hsbuilder_shadow"
HSB_MYSQL_SHADOW_USER="u814151968_builder"
HSB_MYSQL_SHADOW_PASSWORD="MY_MYSQL_PASSWORD"

DATABASE_URL="mysql://u814151968_builder:MY_MYSQL_PASSWORD@MY_MYSQL_HOST:3306/u814151968_hsbuilder"
SHADOW_DATABASE_URL="mysql://u814151968_builder:MY_MYSQL_PASSWORD@MY_MYSQL_HOST:3306/u814151968_hsbuilder_shadow"
